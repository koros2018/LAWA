# LAWA 开发环境变量
# 复制此文件为 .env 并根据需要修改

# 应用
APP_NAME=LAWA
DEBUG=true

# 服务器
API_HOST=0.0.0.0
API_PORT=6288

# 数据库 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=lawa
DB_PASSWORD=lawa_dev
DB_NAME=lawa

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET=lawa-dev-secret-change-in-production

# LLM (DeepSeek)
LLM_PROVIDER=deepseek
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL_DEFAULT=deepseek-chat
LLM_MODEL_PRO=deepseek-reasoner

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# 日志
LOG_LEVEL=INFO
